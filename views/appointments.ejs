<h2>Rendez-vous</h2>

<a href="/appointments/new" class="btn btn-add">Ajouter un rendez-vous</a>

<table class="appointments-table">
  <thead>
    <tr>
      <th>Client</th>
      <th>Responsable</th>
      <th>Date et heure</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% appointments.forEach(a=> { %>
      <tr>
        <td title="<%= a.Clients && a.Clients.length ? a.Clients.map(c => c.name).join(', ') : '—' %>">
          <% if (a.Clients && a.Clients.length) { %>
            <%= a.Clients.map(c=> c.name).join(', ') %>
              <% } else { %>
                —
                <% } %>
        </td>

        <td title="<%= a.User ? a.User.name : '—' %>">
          <%= a.User ? a.User.name : '—' %>
        </td>

        <td title="<%= a.datetime ? new Date(a.datetime).toLocaleString() : '—' %>">
          <%= a.datetime ? new Date(a.datetime).toLocaleString() : '—' %>
        </td>

        <td class="actions">
          <% if (currentUser && a.userId===currentUser.id) { %>
            <div class="table-actions">
              <a href="/appointments/<%= a.id %>/edit" class="table-action-link table-action-edit">
                Détails
              </a>

              <form action="/appointments/<%= a.id %>?_method=DELETE" method="POST"
                class="table-action-form delete-form-appointment">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="table-action-button table-action-delete">
                  Supprimer
                </button>
              </form>
            </div>
            <% } else { %>
              <span>—</span>
              <% } %>
        </td>
      </tr>
      <% }) %>
  </tbody>
</table>